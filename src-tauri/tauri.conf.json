{
  "productName": "oorouter",
  "version": "1.2.0",
  "identifier": "com.oorouter.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": false,
    "windows": [
      {
        "label": "main",
        "title": "oorouter",
        "width": 720,
        "height": 520,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://localhost:* http://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {}
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVBOUFFOTBDNjRCQjlEMEYKUldRUG5idGtET21hNnVEOG9VRW1UVTcwY3JIYUpqVXlxUFk2UjNvM1hSUklPSGo4RFppdS8wVDgK",
      "endpoints": [
        "https://github.com/pelogvc/oorouter/releases/latest/download/latest.json"
      ]
    }
  }
}
